                        <event activity="initialize" name="event__initialize">
                           <script>
// INTELLIPAY ROW – hide if all amounts = 0 OR empty
var net  = Num(this.Cell4.rawValue);
var vat  = Num(this.Cell5.rawValue);
var tot  = Num(this.Cell6.rawValue);

// If no ES data OR values = zero → hide the row
if (net == 0.00 AND vat == 0.00 AND tot == 0.00) then
    this.presence = "hidden";
else
    this.presence = "visible";
endif
</script>
                        </event>
